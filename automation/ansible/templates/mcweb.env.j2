# Minecraft web admin environment file
# Managed by Ansible — do not edit by hand.
MC_MODS_DIR={{ minecraft_data_dir }}/mods
MC_DISABLED_DIR={{ minecraft_data_dir }}/disabled-mods
MC_CTL_CMD=/usr/local/bin/minecraftctl
MC_BIND_IP={{ mcweb_bind_ip | default('0.0.0.0') }}
MC_PORT={{ mcweb_port | default(8080) }}
MC_MAX_UPLOAD_MB={{ mcweb_max_upload_mb | default(64) }}
MC_SECRET_KEY={{ mcweb_secret_key }}
MC_PASSWORD_HASH={{ mcweb_password_hash }}
